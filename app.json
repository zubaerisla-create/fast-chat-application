{
  "expo": {
    "name": "fast-chat-app",
    "slug": "fast-chat-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fastchatapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "audio",
          "voip",
          "fetch",
          "remote-notification"
        ],
        "NSCameraUsageDescription": "Camera access is required for video calls.",
        "NSMicrophoneUsageDescription": "Microphone access is required for calls."
      },
      "bundleIdentifier": "com.zubaer-official.fastchatapp"
    },
    "android": {
      "icon": "./assets/images/icon.png",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "INTERNET",
        "USE_FULL_SCREEN_INTENT",
        "MANAGE_OWN_CALLS",
        "READ_PHONE_STATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.zubaer_official.fastchatapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-audio",
      "expo-video",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#6366F1",
          "androidMode": "default",
          "androidCollapsedTitle": "New messages"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "enableMinifyInReleaseBuilds": true
          }
        }
      ],
      "expo-asset",
      "./withApkSplit.js",
      "@config-plugins/react-native-callkeep",
      [
        "@react-native-firebase/app",
        {}
      ],
      [
        "@react-native-firebase/messaging",
        {}
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "45ab59a3-bc32-49aa-b427-ea6896abdaf7"
      }
    }
  }
}
